<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TonManager Test Tool"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Network:"
                android:textStyle="bold"/>

            <RadioGroup
                android:id="@+id/radioGroupNetwork"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <RadioButton
                    android:id="@+id/radioMainnet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mainnet"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/radioTestnet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Testnet"/>
            </RadioGroup>

            <Button
                android:id="@+id/btnGenerateMnemonic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Generate Random Mnemonic"/>

            <EditText
                android:id="@+id/etMnemonic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#f0f0f0"
                android:padding="12dp"
                android:layout_marginVertical="8dp"
                android:hint="Enter your 12 or 24 words seed phrase here"
                android:textSize="14sp"
                android:gravity="top|start"
                android:minLines="3"
                android:inputType="textMultiLine"/>

            <Space android:layout_width="match_parent" android:layout_height="16dp"/>

            <Button
                android:id="@+id/btnGetAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get Address"/>

            <Button
                android:id="@+id/btnGetBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get Balance"/>

            <Button
                android:id="@+id/btnGetChainId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get Chain ID"/>

            <Button
                android:id="@+id/btnGetHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get Transaction History"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Transfer TON:"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <EditText
                android:id="@+id/etToAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Destination Address (EQ...)"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Amount (e.g. 0.01)"
                android:inputType="numberDecimal"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etMemo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Memo (optional)"
                android:textSize="14sp"/>

            <Button
                android:id="@+id/btnTransfer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Execute Transfer"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Output Log:"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <TextView
                android:id="@+id/textViewOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#000"
                android:textColor="#0f0"
                android:padding="8dp"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:minHeight="200dp"
                android:text="> Ready..."/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
